# VibeShield Configuration
# Copy to .env.local and customize

# === Public URL ===
# Used for metadata, sitemap, and robots.txt. Falls back to https://vibeshield.dev
# NEXT_PUBLIC_URL=https://vibeshield.dev

# === Docker ===
# Set to 1 to enable standalone output mode (used by Dockerfile)
# STANDALONE=1

# === Redis (optional - falls back to in-memory storage) ===
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# === Authentication ===
# Set to require API keys for write endpoints. Multiple keys comma-separated.
# VIBESHIELD_API_KEY=key1,key2,key3

# === CORS ===
# Allowed origins for cross-origin API access (comma-separated).
# Same-origin requests always work. In development, localhost is allowed automatically.
# VIBESHIELD_CORS_ORIGINS=https://my-dashboard.example.com,https://ci.example.com

# === Webhook Security ===
# HMAC-SHA256 secret for signing webhook callbacks
# VIBESHIELD_WEBHOOK_SECRET=your-webhook-secret

# === Persistence ===
# Directory for SQLite database (scan history survives restarts)
# VIBESHIELD_DATA_DIR=.vibeshield-data

# === Logging ===
# Log level: debug, info, warn, error
# LOG_LEVEL=info

# === Scanner Limits ===
# VIBESHIELD_MODULE_TIMEOUT_MS=120000      # Max time per module (ms)
# VIBESHIELD_MAX_FINDINGS_PER_MODULE=8     # Max findings from a single module
# VIBESHIELD_BATCH_SIZE=21                 # Parallel module batch size
# VIBESHIELD_CIRCUIT_BREAKER=4             # Consecutive failures before abort
# VIBESHIELD_MAX_JS_FILES=40              # Max JS files to fetch during recon
# VIBESHIELD_MAX_CONCURRENT=10            # Max concurrent scans
# VIBESHIELD_RATE_TARGET=3                # Max scans per target per window
# VIBESHIELD_RATE_IP=20                   # Max scans per IP per window
# VIBESHIELD_RATE_WINDOW_MS=300000        # Rate limit window (ms)
# VIBESHIELD_MAX_SCANS=100               # Max scans in memory
# VIBESHIELD_STALE_TIMEOUT_MS=300000     # Stale scan timeout (ms)
# VIBESHIELD_FETCH_TIMEOUT_MS=10000      # Default fetch timeout (ms)
