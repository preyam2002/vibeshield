# Redis (optional - falls back to in-memory storage)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Scanner Configuration (all optional, shown with defaults)
# VIBESHIELD_MODULE_TIMEOUT_MS=120000
# VIBESHIELD_MAX_FINDINGS_PER_MODULE=8
# VIBESHIELD_BATCH_SIZE=21
# VIBESHIELD_CIRCUIT_BREAKER=4
# VIBESHIELD_MAX_CONCURRENT=10
# VIBESHIELD_RATE_IP=20
# VIBESHIELD_RATE_TARGET=3
# VIBESHIELD_RATE_WINDOW_MS=300000
# VIBESHIELD_FETCH_TIMEOUT_MS=10000
